      <div>
        <p class="font-display font-semibold text-3xl">4.2 hrs</p>
        <p class="text-sm text-ink/50 mt-1">saved per hire</p>
      </div>
      <div>
        <p class="font-display font-semibold text-3xl">98%</p>
        <p class="text-sm text-ink/50 mt-1">candidates get a reply</p>
      </div>
