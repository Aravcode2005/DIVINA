        <div class="flex items-center gap-4">
          <div class="w-11 h-11 rounded-full bg-paper border border-mist flex items-center justify-center text-amber shrink-0"><i class="fa-solid fa-envelope-open-text"></i></div>
          <p class="text-sm font-medium">Resume received</p>
        </div>
        <div class="pipe-track-v h-8 ml-[1.35rem]"><span class="pipe-dot-v" style="animation-delay:.5s"></span></div>
        <div class="flex items-center gap-4">
          <div class="w-11 h-11 rounded-full bg-paper border border-mist flex items-center justify-center text-cobalt shrink-0"><i class="fa-solid fa-wand-magic-sparkles"></i></div>
