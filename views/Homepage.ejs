      </div>
    </div>
  </div>
</section>


<section id="always-on" class="px-6 lg:px-10 py-24 lg:py-32 bg-ink text-paper overflow-hidden">
  <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
