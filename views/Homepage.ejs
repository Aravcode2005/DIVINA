<title>Hireflow — Hiring, automated end to end</title>
<meta name="description" content="Hireflow posts your roles to LinkedIn, reads every resume that lands in your inbox, replies to candidates automatically, and books the interview." />

<script src="https://cdn.tailwindcss.com"></script>
<script>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          paper: '#FAFAF8',
          ink:   '#13151A',
          cobalt:'#2952FF',
          amber: '#FF9D2E',
          sage:  '#1FAA70',
          mist:  '#E7E8EC',
        },
        fontFamily: {
          display: ['"Space Grotesk"', 'sans-serif'],
          body: ['"Inter"', 'sans-serif'],
          mono: ['"JetBrains Mono"', 'monospace'],
        },
      },
    },
  };
</script>

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

<style>
  html { scroll-behavior: smooth; }
  body { font-family: 'Inter', sans-serif; background: #FAFAF8; color: #13151A; }
  .font-display { font-family: 'Space Grotesk', sans-serif; }
  .font-mono { font-family: 'JetBrains Mono', monospace; }

  .reveal { opacity: 0; transform: translateY(22px); transition: opacity .7s ease, transform .7s ease; }
  .reveal.is-visible { opacity: 1; transform: translateY(0); }

  #siteNav.scrolled { background: rgba(250,250,248,0.8); backdrop-filter: blur(12px); box-shadow: 0 1px 0 rgba(19,21,26,0.06); }

  
  .pipe-track { position: relative; height: 2px; background: #E7E8EC; overflow: hidden; border-radius: 2px; }
  .pipe-dot { position: absolute; top: 50%; left: -4%; width: 8px; height: 8px; margin-top: -4px; border-radius: 50%; background: #2952FF; box-shadow: 0 0 10px rgba(41,82,255,.7); animation: travel 2.6s linear infinite; }
  @keyframes travel {
    0%   { left: -4%; opacity: 0; }
    8%   { opacity: 1; }
    90%  { opacity: 1; }
    100% { left: 100%; opacity: 0; }
  }

  .pipe-track-v { position: relative; width: 2px; background: #E7E8EC; border-radius: 2px; }
  .pipe-dot-v { position: absolute; left: 50%; top: -4%; width: 8px; height: 8px; margin-left: -4px; border-radius: 50%; background: #2952FF; box-shadow: 0 0 10px rgba(41,82,255,.7); animation: travelV 2.6s linear infinite; }
  @keyframes travelV {
    0%   { top: -4%; opacity: 0; }
    8%   { opacity: 1; }
    90%  { opacity: 1; }
    100% { top: 100%; opacity: 0; }
  }


  #logFeed div { animation: logIn .4s ease; }
  @keyframes logIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }


  .marquee-mask { -webkit-mask-image: linear-gradient(to bottom, transparent, black 12%, black 88%, transparent); mask-image: linear-gradient(to bottom, transparent, black 12%, black 88%, transparent); }
  .marquee-track { animation: marquee 14s linear infinite; }
  @keyframes marquee { 0% { transform: translateY(0); } 100% { transform: translateY(-50%); } }

  @media (prefers-reduced-motion: reduce) {
    .pipe-dot, .pipe-dot-v, .marquee-track, #logFeed div { animation: none !important; }
    .reveal { opacity: 1 !important; transform: none !important; transition: none !important; }
  }

  :focus-visible { outline: 2px solid #2952FF; outline-offset: 3px; }
</style>
</head>

