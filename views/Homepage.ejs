<section id="top" class="pt-40 pb-20 px-6 lg:px-10">
  <div class="max-w-5xl mx-auto text-center">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-cobalt mb-6">From job post to booked interview</p>

    <h1 class="font-display font-semibold text-[clamp(2.4rem,6vw,4.6rem)] leading-[1.05] tracking-tight">
      Post a job.<br />
      Walk into a calendar<br class="hidden sm:block" /> full of interviews.
    </h1>

    <p class="mt-7 text-lg text-ink/60 max-w-2xl mx-auto leading-relaxed">
      Hireflow publishes your opening to LinkedIn, reads every resume that lands in your inbox, replies to each candidate, and books the interview — before your coffee's cold.
    </p>

    <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
      <a href="#cta" class="bg-cobalt text-white text-sm font-medium px-7 py-3.5 rounded-full hover:bg-ink transition-colors">
        Start free trial
      </a>
      <a href="#pipeline" class="flex items-center gap-2 text-sm font-medium text-ink/70 hover:text-ink px-7 py-3.5 rounded-full border border-mist transition-colors">
        <i class="fa-solid fa-play text-xs"></i> Watch it work
      </a>
    </div>
  </div>


  <div id="pipeline" class="max-w-5xl mx-auto mt-20 reveal">
    <div class="rounded-2xl border border-mist bg-white p-7 lg:p-9 shadow-sm">

     
      <div class="hidden md:grid grid-cols-5 gap-0 items-start">
        <!-- step 1 -->
        <div class="flex flex-col items-center text-center px-2">
          <div class="w-12 h-12 rounded-full bg-paper border border-mist flex items-center justify-center text-cobalt"><i class="fa-brands fa-linkedin-in"></i></div>
          <p class="font-mono text-[11px] mt-3 text-ink/45">01</p>
          <p class="text-sm font-medium mt-1">Posted</p>
        </div>
        <div class="pipe-track mt-6"><span class="pipe-dot" style="animation-delay:0s"></span></div>
  
        <div class="flex flex-col items-center text-center px-2" style="grid-column:2/3"></div>
      </div>

      <!-- the grid above is awkward for 5 nodes + 4 connectors, so we lay it out manually below -->
      <div class="hidden md:flex items-start justify-between">
        <div class="flex flex-col items-center text-center w-1/5">
          <div class="w-12 h-12 rounded-full bg-paper border border-mist flex items-center justify-center text-cobalt"><i class="fa-brands fa-linkedin-in"></i></div>
          <p class="font-mono text-[11px] mt-3 text-ink/45">01</p>
          <p class="text-sm font-medium mt-1">Posted</p>
        </div>
        <div class="pipe-track flex-1 mt-6 mx-1"><span class="pipe-dot" style="animation-delay:0s"></span></div>

        <div class="flex flex-col items-center text-center w-1/5">
          <div class="w-12 h-12 rounded-full bg-paper border border-mist flex items-center justify-center text-amber"><i class="fa-solid fa-envelope-open-text"></i></div>
          <p class="font-mono text-[11px] mt-3 text-ink/45">02</p>
          <p class="text-sm font-medium mt-1">Resume in</p>
        </div>
        <div class="pipe-track flex-1 mt-6 mx-1"><span class="pipe-dot" style="animation-delay:.5s"></span></div>

        <div class="flex flex-col items-center text-center w-1/5">
          <div class="w-12 h-12 rounded-full bg-paper border border-mist flex items-center justify-center text-cobalt"><i class="fa-solid fa-wand-magic-sparkles"></i></div>
          <p class="font-mono text-[11px] mt-3 text-ink/45">03</p>
          <p class="text-sm font-medium mt-1">Parsed</p>
        </div>
        <div class="pipe-track flex-1 mt-6 mx-1"><span class="pipe-dot" style="animation-delay:1s"></span></div>

        <div class="flex flex-col items-center text-center w-1/5">
          <div class="w-12 h-12 rounded-full bg-paper border border-mist flex items-center justify-center text-amber"><i class="fa-solid fa-reply"></i></div>
          <p class="font-mono text-[11px] mt-3 text-ink/45">04</p>
          <p class="text-sm font-medium mt-1">Replied</p>
        </div>
        <div class="pipe-track flex-1 mt-6 mx-1"><span class="pipe-dot" style="animation-delay:1.5s"></span></div>

        <div class="flex flex-col items-center text-center w-1/5">
