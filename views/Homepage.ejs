<script>
  
  const siteNav = document.getElementById('siteNav');
  const onScroll = () => siteNav.classList.toggle('scrolled', window.scrollY > 8);
  document.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
  const staffMenuBtn = document.getElementById('staffMenuBtn');
  const staffMenu = document.getElementById('staffMenu');
  const staffChevron = document.getElementById('staffChevron');
  staffMenuBtn.addEventListener('click', () => {
    const isOpen = !staffMenu.classList.contains('hidden');
    staffMenu.classList.toggle('hidden');
    staffMenuBtn.setAttribute('aria-expanded', String(!isOpen));
    staffChevron.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
  });
  document.addEventListener('click', (e) => {
    if (!staffMenuBtn.contains(e.target) && !staffMenu.contains(e.target)) {
      staffMenu.classList.add('hidden');
      staffMenuBtn.setAttribute('aria-expanded', 'false');
      staffChevron.style.transform = 'rotate(0deg)';
    }
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      staffMenu.classList.add('hidden');
      staffMenuBtn.setAttribute('aria-expanded', 'false');
    }
  });

  const mobileMenuBtn = document.getElementById('mobileMenuBtn');
  const mobileMenu = document.getElementById('mobileMenu');
  mobileMenuBtn.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden');
    mobileMenu.classList.toggle('hidden');
    mobileMenuBtn.setAttribute('aria-expanded', String(!isOpen));
    mobileMenuBtn.innerHTML = isOpen ? '<i class="fa-solid fa-bars text-lg"></i>' : '<i class="fa-solid fa-xmark text-lg"></i>';
  });
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduceMotion) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  } else {
    document.querySelectorAll('.reveal').forEach((el) => el.classList.add('is-visible'));
  }

  const logLines = [
    'New application — Senior Backend Engineer',
    'Resume parsed — 87% match, 4 yrs relevant exp',
    'Reply sent — advancing to screening',
    'Interview slot confirmed — Thu 3:00 PM',
    'New application — Product Designer',
    'Resume parsed — 92% match, portfolio attached',
    'Reply sent — moving to next round',
    'New application — Backend Engineer',
  ];
  const logFeed = document.getElementById('logFeed');
  let logIndex = 0;

  function timestamp() {
    const d = new Date();
    return d.toTimeString().slice(0, 8);
  }

  function pushLog() {
    const line = document.createElement('div');
    line.innerHTML = `<span class="text-ink/35">${timestamp()}</span>  ▸  ${logLines[logIndex % logLines.length]}`;
    logFeed.appendChild(line);
    while (logFeed.children.length > 4) logFeed.removeChild(logFeed.firstChild);
    logIndex++;
  }

  pushLog();
  if (!reduceMotion) {
    setInterval(pushLog, 2200);
  } else {
    for (let i = 0; i < 3; i++) pushLog();
  }
</script>

