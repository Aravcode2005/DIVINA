<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>

  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'ui-sans-serif', 'system-ui'],
            display: ['Space Grotesk', 'ui-sans-serif', 'system-ui'],
            mono: ['JetBrains Mono', 'ui-monospace', 'monospace'],
          },
          colors: {
            brand: {
              50:  '#eef1ff',
              100: '#dee4fe',
              500: '#3b5bfb',
              600: '#3049e0',
              700: '#2538b8',
            },
          },
        },
      },
    };
  </script>

  <style>
    body { font-family: 'Inter', sans-serif; background:#fafaf9; }
    @media (prefers-reduced-motion: no-preference) {
      .fade-up { animation: fadeUp .6s ease both; }
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: none; }
    }
    input:focus-visible, button:focus-visible, a:focus-visible {
      outline: 2px solid #3b5bfb;
      outline-offset: 2px;
    }
  </style>
</head>
<body class="text-[#0a0a0a] antialiased">
  <header class="border-b border-gray-100">
    <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
      <a href="/Homepage" class="flex items-center gap-2 font-display font-semibold text-[15px]">
        <span class="w-2 h-2 rounded-full bg-brand-500 inline-block"></span>
        hireflow
      </a>
      <div class="flex items-center gap-3 text-sm">
        <span class="text-gray-500 hidden sm:inline">New to Hireflow?</span>
        <a href="/admin/signup" id="signup" class="font-semibold text-brand-600 hover:text-brand-700 transition">Create an account</a>
      </div>
    </div>
  </header>

  <main class="max-w-md mx-auto px-6 py-16 sm:py-24">
    <div class="fade-up text-center mb-8">
      <p class="font-mono text-xs font-medium uppercase tracking-[0.2em] text-brand-600 mb-4">Welcome back</p>
      <h1 class="font-display font-bold text-4xl leading-[1.1] tracking-tight mb-4">
        Sign in to Hireflow.
      </h1>
      <p class="text-gray-500 text-[15px] leading-relaxed">
        Your jobs, candidates, and interviews are right where you left them.
      </p>
    </div>

    <div class="fade-up bg-white border border-gray-200 rounded-2xl shadow-[0_1px_2px_rgba(0,0,0,0.04),0_12px_32px_-12px_rgba(0,0,0,0.08)] p-7 sm:p-9" style="animation-delay:.1s">

      <form method="POST" action="/admin/signin" id="adminSignin" class="space-y-4">

        <div>
          <label for="adminName" class="block text-xs font-medium text-gray-500 mb-1.5">Full name</label>
          <div class="relative">
            <i class="fa-regular fa-user absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
            <input type="text" id="adminName" name="adminName" placeholder="Jordan Lee" required
              class="w-full rounded-xl border border-gray-200 pl-10 pr-4 py-2.5 text-sm placeholder:text-gray-400 focus:outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-500/15 transition">
          </div>
        </div>

        <div>
          <label for="adminEmail" class="block text-xs font-medium text-gray-500 mb-1.5">Email</label>
          <div class="relative">
            <i class="fa-regular fa-envelope absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
            <input type="email" id="adminEmail" name="adminEmail" placeholder="you@company.com" required
              class="w-full rounded-xl border border-gray-200 pl-10 pr-4 py-2.5 text-sm placeholder:text-gray-400 focus:outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-500/15 transition">
          </div>
        </div>

        <div>
          <div class="flex items-center justify-between mb-1.5">
            <label for="adminPassword" class="block text-xs font-medium text-gray-500">Password</label>
            <a href="/admin/forgotPassword" id="reset" class="text-xs font-semibold text-brand-600 hover:text-brand-700 transition">Forgot password?</a>
          </div>
          <div class="relative">
            <i class="fa-solid fa-lock absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
            <input type="password" id="adminPassword" name="adminPassword" placeholder="••••••••" required
              class="w-full rounded-xl border border-gray-200 pl-10 pr-10 py-2.5 text-sm placeholder:text-gray-400 focus:outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-500/15 transition">
            <button type="button" id="togglePassword" aria-label="Show password"
              class="absolute right-3.5 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition">
              <i class="fa-regular fa-eye text-sm"></i>
            </button>
          </div>
        </div>

        <button type="submit" id="adminSubmit" name="adminSubmit"
          class="w-full bg-[#0a0a0a] hover:bg-black text-white rounded-full font-semibold text-sm py-3 mt-2 transition">
          Sign in
        </button>
      </form>

      <div class="my-7 flex items-center gap-3">
        <div class="h-px bg-gray-100 flex-1"></div>
        <span class="text-xs text-gray-400">or continue with</span>
        <div class="h-px bg-gray-100 flex-1"></div>
      </div>

      <div class="grid grid-cols-3 gap-3">
        <a href="/admin/auth/googlesingin" id="google" aria-label="Continue with Google"
          class="flex items-center justify-center rounded-xl border border-gray-200 py-2.5 hover:bg-gray-50 hover:border-gray-300 transition">
          <i class="fa-brands fa-google text-[15px]"></i>
        </a>
        <a href="/admin/auth/Xsignin" id="X" aria-label="Continue with X"
          class="flex items-center justify-center rounded-xl border border-gray-200 py-2.5 hover:bg-gray-50 hover:border-gray-300 transition">
          <i class="fa-brands fa-x-twitter text-[15px]"></i>
        </a>
        <a href="/admin/auth/Linkedinsignin" id="Linkedin" aria-label="Continue with LinkedIn"
          class="flex items-center justify-center rounded-xl border border-gray-200 py-2.5 hover:bg-gray-50 hover:border-gray-300 transition">
          <i class="fa-brands fa-linkedin text-[15px]"></i>
        </a>
      </div>

      <p class="text-center text-sm text-gray-500 mt-7">
        New to Hireflow?
        <a href="/admin/signup" class="font-semibold text-brand-600 hover:text-brand-700">Create an account</a>
      </p>
    </div>
  </main>

  <script>

    const toggleBtn = document.getElementById('togglePassword');
    const passwordInput = document.getElementById('adminPassword');
    if (toggleBtn && passwordInput) {
      toggleBtn.addEventListener('click', () => {
        const isHidden = passwordInput.type === 'password';
        passwordInput.type = isHidden ? 'text' : 'password';
        toggleBtn.setAttribute('aria-label', isHidden ? 'Hide password' : 'Show password');
        toggleBtn.innerHTML = isHidden
          ? '<i class="fa-regular fa-eye-slash text-sm"></i>'
          : '<i class="fa-regular fa-eye text-sm"></i>';
      });
    }
  </script>

</body>
</html>
